SOURCE_JIRA_BASE_URL=https://your-source.atlassian.net
SOURCE_JIRA_EMAIL=source-user@example.com
SOURCE_JIRA_API_TOKEN=source_api_token

TARGET_JIRA_BASE_URL=https://your-target.atlassian.net
TARGET_JIRA_EMAIL=target-user@example.com
TARGET_JIRA_API_TOKEN=target_api_token

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/jira_migration
JIRA_MAPPING_FILE=./mapping.json

# Optional fallback if mapped issue type is missing in target.
DEFAULT_TARGET_ISSUE_TYPE=Task

# TLS options. Prefer JIRA_CA_BUNDLE for corporate/internal CAs.
JIRA_SSL_VERIFY=true
JIRA_CA_BUNDLE=
JIRA_TRUST_ENV=true
